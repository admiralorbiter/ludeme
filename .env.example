# Ludeme environment variables
# Copy this file to .env:  Copy-Item .env.example .env

# SQLite database URL — creates the file automatically on first connect
DATABASE_URL=sqlite://ludeme.db?mode=rwc

# Server port (default: 3000)
# SERVER_PORT=3000

# API base URL for the SvelteKit shell (default: http://localhost:3000)
# Set this when deploying to a different host or port.
# PUBLIC_API_BASE=http://localhost:3000
