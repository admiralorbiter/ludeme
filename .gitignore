# =============================================================================
# Rust
# =============================================================================
/target/
**/*.rs.bk
*.pdb
**/mutants.out*/

# =============================================================================
# SvelteKit / Vite / Node
# =============================================================================
node_modules/
shell/node_modules/

# SvelteKit build outputs
shell/.svelte-kit/
shell/build/
shell/dist/

# Compiled WASM demo outputs (generated by build-demo.ps1 — not source)
shell/static/demos/*/

# Vite cache
shell/.vite/

# npm / yarn / pnpm lockfiles (keep package-lock.json, ignore others)
yarn.lock
pnpm-lock.yaml

# =============================================================================
# Environment & secrets — never commit these
# =============================================================================
.env
.env.local
.env.*.local
# .env.example IS tracked — it's the safe template

# =============================================================================
# SQLite database files (runtime data — never commit)
# =============================================================================
*.db
*.db-shm
*.db-wal

# =============================================================================
# Editor & OS
# =============================================================================
.idea/
.vscode/settings.json
*.swp
*.swo
.DS_Store
Thumbs.db

# =============================================================================
# WASM build outputs (generated — do not commit)
# =============================================================================
crates/ludeme-demos/**/pkg/
crates/ludeme-demos/**/*.wasm
